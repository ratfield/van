<LinearLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	android:layout_height="wrap_content"
	android:layout_width="fill_parent"
	android:layout_gravity="top"
	android:background="?overlay_background_color"
	android:elevation="2dp"
	android:orientation="vertical"
	android:paddingBottom="8dip">

	<!-- Стандартный блок: Прогресс текущего трека -->
	<LinearLayout
		android:layout_height="wrap_content"
		android:layout_width="fill_parent"
		android:orientation="horizontal">
		<TextView
			android:id="@+id/elapsed"
			android:layout_height="wrap_content"
			android:layout_width="wrap_content"
			android:layout_gravity="center"
			android:paddingLeft="5dip" />
		<SeekBar
			android:id="@+id/seek_bar"
			android:layout_height="wrap_content"
			android:layout_width="0px"
			android:layout_gravity="center"
			android:paddingTop="7dip"
			android:paddingBottom="7dip"
			android:paddingLeft="18dip"
			android:paddingRight="18dip"
			android:layout_weight="1" />
		<TextView
			android:id="@+id/duration"
			android:layout_height="wrap_content"
			android:layout_width="wrap_content"
			android:layout_gravity="center"
			android:paddingRight="5dip" />
	</LinearLayout>

	<!-- Новый блок: Глобальный прогресс папки (книги) -->
	<LinearLayout
		android:layout_height="wrap_content"
		android:layout_width="fill_parent"
		android:orientation="horizontal"
		android:layout_marginTop="4dip">
		<SeekBar
			android:id="@+id/folder_seek_bar"
			android:layout_height="wrap_content"
			android:layout_width="0px"
			android:layout_gravity="center"
			android:paddingTop="4dip"
			android:paddingBottom="4dip"
			android:paddingLeft="18dip"
			android:paddingRight="18dip"
			android:layout_weight="1"
			android:focusable="false"
			android:clickable="false" />
	</LinearLayout>

	<!-- Текстовая строка с подробной информацией под ползунком папки -->
	<LinearLayout
		android:layout_height="wrap_content"
		android:layout_width="fill_parent"
		android:orientation="horizontal"
		android:gravity="center_horizontal"
		android:layout_marginTop="2dip">
		<TextView
			android:id="@+id/folder_elapsed"
			android:layout_height="wrap_content"
			android:layout_width="wrap_content"
			android:textSize="12sp"
			android:text="Прослушано 00:00 из 00:00"
			android:paddingRight="15dip" />
		<TextView
			android:id="@+id/folder_duration"
			android:layout_height="wrap_content"
			android:layout_width="wrap_content"
			android:textSize="12sp"
			android:text="Осталось 00:00" />
	</LinearLayout>

</LinearLayout>
